PORT=3085
JWT_SECRET=change_this_to_random_string
NODE_ENV=production

# AI Features (optional — app works fully without this)
CLAUDE_API_KEY=

# Email / Weekly Digest (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DIGEST_FROM=familyhub@yourdomain.com
DIGEST_TO=comma,separated,emails

# Web Push VAPID (generated by installer)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@familyhub.local

# N8N Integration (optional)
WEBHOOK_SECRET=
N8N_WEBHOOK_URL=

# Backup
BACKUP_PATH=/opt/family-hub/backups

# Paperless (leave blank until NFS is mounted)
PAPERLESS_CONSUME_PATH=
